<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gui.DashboardController"
      spacing="0"
      style="-fx-background-color: #f5f6fa; -fx-padding: 24;">

    <Label text="Pages / Dashboard" styleClass="breadcrumb"/>
    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 4 0 20 0;">
        <Label text="Application Tracker" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        <Button text="+ New Application" styleClass="primary-button" onAction="#handleNewApplication"/>
    </HBox>

    <!-- Stat cards -->
    <HBox spacing="14" style="-fx-padding: 0 0 20 0;">
        <VBox styleClass="stat-card, stat-card-total" HBox.hgrow="ALWAYS">
            <Label text="TOTAL APPS" styleClass="stat-label"/>
            <Label fx:id="statTotal" text="—" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card, stat-card-applied" HBox.hgrow="ALWAYS">
            <Label text="APPLIED" styleClass="stat-label"/>
            <Label fx:id="statApplied" text="—" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card, stat-card-interviewing" HBox.hgrow="ALWAYS">
            <Label text="INTERVIEWING" styleClass="stat-label"/>
            <Label fx:id="statInterviewing" text="—" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card, stat-card-offers" HBox.hgrow="ALWAYS">
            <Label text="OFFERS" styleClass="stat-label"/>
            <Label fx:id="statOffers" text="—" styleClass="stat-value-accent"/>
        </VBox>
        <VBox styleClass="stat-card, stat-card-rejected" HBox.hgrow="ALWAYS">
            <Label text="REJECTED" styleClass="stat-label"/>
            <Label fx:id="statRejected" text="—" styleClass="stat-value"/>
        </VBox>
    </HBox>

    <!-- Charts row -->
    <HBox spacing="14" style="-fx-padding: 0 0 20 0;" minHeight="240">

        <VBox styleClass="card" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="Applications by Status" styleClass="section-title" HBox.hgrow="ALWAYS"/>
            </HBox>
            <BarChart fx:id="statusBarChart"
                      VBox.vgrow="ALWAYS"
                      animated="false"
                      legendVisible="false"
                      style="-fx-padding: 0;">
                <xAxis>
                    <CategoryAxis fx:id="barXAxis" tickLabelRotation="0"/>
                </xAxis>
                <yAxis>
                    <NumberAxis fx:id="barYAxis" minorTickVisible="false" tickUnit="1"/>
                </yAxis>
            </BarChart>
        </VBox>

        <VBox styleClass="card" minWidth="270" maxWidth="310">
            <Label text="Status Breakdown" styleClass="section-title"/>
            <PieChart fx:id="statusPieChart"
                      VBox.vgrow="ALWAYS"
                      animated="false"
                      labelsVisible="false"
                      legendVisible="true"
                      legendSide="BOTTOM"/>
        </VBox>

    </HBox>

    <!-- Search -->
    <TextField fx:id="searchField"
               promptText="&#x1f50d;  Search by company or role…"
               styleClass="search-field"
               onKeyReleased="#handleSearch"
               style="-fx-max-width: 360;">
        <VBox.margin>
            <Insets bottom="14"/>
        </VBox.margin>
    </TextField>

    <!-- Applications table -->
    <TableView fx:id="applicationTable" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colCompany"  text="Company"  prefWidth="170"/>
            <TableColumn fx:id="colRole"     text="Role"     prefWidth="170"/>
            <TableColumn fx:id="colStatus"   text="Status"   prefWidth="130"/>
            <TableColumn fx:id="colDeadline" text="Deadline" prefWidth="110"/>
            <TableColumn fx:id="colAction"   text=""         prefWidth="70" sortable="false"/>
        </columns>
        <placeholder>
            <Label text="No applications yet — click '+ New Application' to get started."
                   style="-fx-text-fill: #a0a4be;"/>
        </placeholder>
    </TableView>

</VBox>
